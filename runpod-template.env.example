# RunPod template environment example.
# Put secrets in RunPod template env vars, not in the Docker image.

PORT=8188
LISTEN=0.0.0.0
RUN_DEP_CHECK=0
COMFYUI_CORS_ORIGIN=*

# Default: refresh /workspace/config/models.json from the bundled manifest each boot.
# Set to 0 only if you intentionally manage /workspace/config/models.json yourself.
MODEL_MANIFEST_REFRESH=1

# Option A: point to a raw JSON manifest in S3/R2/GitHub/Hugging Face.
MODEL_MANIFEST_URL=https://raw.githubusercontent.com/grawthings-beep/zit-comfyui-runpod/main/config/zit-models.json

# Option B: paste compact JSON directly into a RunPod env var.
# Example:
# MODEL_MANIFEST_JSON={"models":[{"name":"base","enabled":true,"url":"https://.../model.safetensors","path":"models/checkpoints/model.safetensors"}]}
MODEL_MANIFEST_JSON=

# Optional. The default manifest uses public Hugging Face files.
CIVITAI_TOKEN={{ RUNPOD_SECRET_CIVITAI_TOKEN }}

# Extra ComfyUI CLI args, for example:
# COMFYUI_ARGS=--disable-auto-launch --preview-method auto
COMFYUI_ARGS=
